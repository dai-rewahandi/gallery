---
import Header from '../components/Header.astro'
import Hero from '../components/Hero.astro'
import Footer from '../components/Footer.astro'
import Zoomin from '../components/Zoomin.astro'
import '../styles/global.css'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Portfolio Galeri Fotografi dairewahandi -
     Programmer & Photographer"
    />
    <link rel="canonical" href={Astro.url} />
    <link rel="shortcut icon" href="fav.svg" type="image/x-icon">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,100..700;1,100..700&family=Merriweather:ital,opsz,wght@0,18..144,300..900;1,18..144,300..900&display=swap"
      rel="stylesheet"
    />
    <title>@de_fotograp</title>
  </head>
  <body class="relative min-h-dvh w-dvw overflow-x-hidden">
    <script is:inline>
      document.body.style.overflow = 'hidden';
    </script>
    <div id="loading-screen" class="fixed inset-0 z-[9999] flex items-center justify-center bg-white transition-opacity duration-700">
      <div class="flex flex-col items-center gap-4">
        <div class="h-12 w-12 animate-spin rounded-full border-4 border-gray-200 border-t-gray-800"></div>
        <p class="text-sm font-medium text-gray-600 animate-pulse uppercase tracking-widest">Loading Gallery</p>
      </div>
    </div>

    <div id="main-content" class="opacity-0 transition-opacity duration-1000">
      <Zoomin />
      <Header />
      <Hero />
      <main class="relative mx-auto max-w-[70%]">
        <slot />
      </main>
      <Footer />
    </div>

    <style>
      body {
        font-family: 'IBM Plex Sans', sans-serif;
      }
    </style>

    <script is:inline>
      async function validateImages() {
        const loader = document.getElementById('loading-screen');
        const content = document.getElementById('main-content');
        
        const priorityImages = Array.from(document.querySelectorAll('img[loading="eager"]'));
        
        const loadImage = (img) => {
          if (img.complete) {
            return img.decode().catch(() => {});
          }
          return new Promise((resolve) => {
            img.onload = () => img.decode().then(resolve).catch(resolve);
            img.onerror = resolve;
          });
        };

        if (priorityImages.length > 0) {
          await Promise.all(priorityImages.map(loadImage));
        }

        if (loader && content) {
          loader.classList.add('opacity-0');
          content.classList.remove('opacity-0');
          document.body.style.overflow = 'auto';
          
          setTimeout(() => {
            loader.style.display = 'none';
          }, 700);
        }
      }

      window.addEventListener('DOMContentLoaded', validateImages);
      if (document.readyState === 'interactive' || document.readyState === 'complete') {
        validateImages();
      }
    </script>
  </body>
</html>
